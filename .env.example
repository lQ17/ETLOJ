# ============================================
# ETLOJ 环境变量示例
# 复制到 server/.env 和 judge/.env 并填入真实值
# ============================================

# ---- server/.env ----
DATABASE_URL=mysql://root:YOUR_PASSWORD@127.0.0.1:3306/etloj
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=your-jwt-secret-here
JUDGE_SECRET=your-judge-secret-here
GO_JUDGE_URL=http://127.0.0.1:5050
PROBLEMS_DIR=/opt/etloj/data/problems
PORT=3000

# ---- judge/.env ----
# JUDGE_SECRET=your-judge-secret-here
