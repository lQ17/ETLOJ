generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  TEACHER
}

enum Difficulty {
  IRON
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  MASTER
  CHAMPION
  LEGENDARY
}

enum SubmissionStatus {
  PENDING
  JUDGING
  AC
  WA
  TLE
  MLE
  RE
  CE
  SE
}

enum ContestMode {
  ACM
  OI
}

enum SolutionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(50)
  email     String?   @unique @db.VarChar(100)
  phone     String?   @unique @db.VarChar(20)
  password  String    @db.VarChar(255)
  avatar    String?   @db.LongText
  signature String?   @db.VarChar(200)
  role      Role      @default(USER)
  isActive      Boolean   @default(true) @map("is_active")
  aiDailyLimit  Int?      @map("ai_daily_limit")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  submissions Submission[]
  contestRanks ContestRank[]
  tagRecords UserTagRecord[]
  problemLists ProblemList[]
  solutions  Solution[]
  announcements Announcement[]
  aiConversations AiConversation[]
  aiUsageLogs AiUsageLog[]

  @@map("users")
}

model Problem {
  id          Int        @id @default(autoincrement())
  slug        String     @unique @db.VarChar(100)
  title       String     @db.VarChar(200)
  difficulty  Difficulty @default(IRON)
  timeLimit   Int        @default(1000) @map("time_limit")
  memoryLimit Int        @default(256) @map("memory_limit")
  filePath    String     @map("file_path") @db.VarChar(500)
  tags        Json?
  isPublic    Boolean    @default(true) @map("is_public")
  score       Int        @default(0) @map("score")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  submissions    Submission[]
  contestProblems ContestProblem[]
  problemLists   ProblemListItem[]
  problemTags    ProblemTag[]
  solutions      Solution[]
  aiConversations AiConversation[]

  @@index([isPublic, difficulty])
  @@map("problems")
}

model Tag {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  problems ProblemTag[]

  @@map("tags")
}

model ProblemTag {
  problemId Int @map("problem_id")
  tagId     Int @map("tag_id")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([problemId, tagId])
  @@map("problem_tags")
}

model Submission {
  id         Int              @id @default(autoincrement())
  problemId  Int              @map("problem_id")
  userId     Int?             @map("user_id")
  code       String           @db.Text
  language   String           @db.VarChar(20)
  status     SubmissionStatus @default(PENDING)
  timeUsed   Int?             @map("time_used")
  memoryUsed Int?             @map("memory_used")
  score      Int?             @map("score")
  createdAt  DateTime         @default(now()) @map("created_at")

  problem   Problem             @relation(fields: [problemId], references: [id], onDelete: Restrict)
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  testcases SubmissionTestCase[]

  @@index([problemId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status, problemId, createdAt]) // 复合索引：大幅优化个人主页 AC 统计查询 (涵盖过滤和分组)
  @@map("submissions")
}

model SubmissionTestCase {
  id           Int              @id @default(autoincrement())
  submissionId Int              @map("submission_id")
  index        Int
  status       SubmissionStatus
  timeUsed     Int?             @map("time_used")
  memoryUsed   Int?             @map("memory_used")
  createdAt    DateTime         @default(now()) @map("created_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_testcases")
}

model Contest {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(200)
  description String?    @db.Text
  mode        ContestMode @default(ACM)
  startTime   DateTime   @map("start_time")
  endTime     DateTime   @map("end_time")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  problems ContestProblem[]
  ranks    ContestRank[]

  @@map("contests")
}

model ContestProblem {
  id        Int @id @default(autoincrement())
  contestId Int @map("contest_id")
  problemId Int @map("problem_id")
  order     Int @default(0)

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Restrict)

  @@unique([contestId, problemId])
  @@map("contest_problems")
}

model ContestRank {
  id        Int @id @default(autoincrement())
  contestId Int @map("contest_id")
  userId    Int? @map("user_id")
  score     Int @default(0)
  penalty   Int @default(0)

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([contestId, userId])
  @@map("contest_ranks")
}

model UserTagRecord {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tag       String   @db.VarChar(100)
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag])
  @@map("user_tag_records")
}

model ProblemList {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(200)
  description String?  @db.Text
  isPublic    Boolean  @default(false) @map("is_public")
  creatorId   Int?     @map("creator_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User?            @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  items   ProblemListItem[]

  @@index([creatorId])
  @@index([isPublic])
  @@map("problem_lists")
}

model ProblemListItem {
  id        Int @id @default(autoincrement())
  listId    Int @map("list_id")
  problemId Int @map("problem_id")
  sortOrder Int @default(0) @map("sort_order")

  list    ProblemList @relation(fields: [listId], references: [id], onDelete: Cascade)
  problem Problem     @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([listId, problemId])
  @@map("problem_list_items")
}

model Solution {
  id           Int            @id @default(autoincrement())
  problemId    Int            @map("problem_id")
  authorId     Int?           @map("author_id")
  content      String         @db.LongText
  status       SolutionStatus @default(PENDING)
  rejectReason String?        @db.Text            @map("reject_reason")
  createdAt    DateTime       @default(now())     @map("created_at")
  updatedAt    DateTime       @updatedAt          @map("updated_at")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  author  User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([problemId])
  @@index([authorId])
  @@index([status])
  @@map("solutions")
}

model Announcement {
  id        Int               @id @default(autoincrement())
  title     String            @db.VarChar(200)
  summary   String            @db.VarChar(500)
  content   String            @db.LongText
  isPinned  Boolean           @default(false) @map("is_pinned")
  status    AnnouncementStatus @default(DRAFT)
  authorId  Int?              @map("author_id")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@index([status])
  @@index([isPinned])
  @@map("announcements")
}

model AiConversation {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  problemId Int      @map("problem_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId])
  @@index([problemId])
  @@unique([userId, problemId])
  @@map("ai_conversations")
}

model AiMessage {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  role           String   @db.VarChar(20)
  content        String   @db.LongText
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model AiProvider {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  apiBase   String   @map("api_base") @db.VarChar(255)
  apiKey    String   @map("api_key") @db.VarChar(255)
  modelName String   @map("model_name") @db.VarChar(100)
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  usageLogs AiUsageLog[]

  @@map("ai_providers")
}

model AiPromptConfig {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  role       String   @db.LongText
  codeRules  String   @map("code_rules") @db.LongText
  replyRules String   @map("reply_rules") @db.LongText
  isActive   Boolean  @default(false) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("ai_prompt_configs")
}

model AiUsageLog {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  providerId   Int?      @map("provider_id")
  providerName String    @map("provider_name") @db.VarChar(100)
  modelName    String    @map("model_name") @db.VarChar(100)
  inputTokens  Int       @default(0) @map("input_tokens")
  outputTokens Int       @default(0) @map("output_tokens")
  totalTokens  Int       @default(0) @map("total_tokens")
  cost         Float     @default(0)
  timeUsedMs   Int       @default(0) @map("time_used_ms")
  status       Int       @default(200)
  source       String    @default("chat") @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at")

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider AiProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerId])
  @@index([providerName])
  @@index([modelName])
  @@index([createdAt])
  @@map("ai_usage_logs")
}
